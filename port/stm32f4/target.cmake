# STM32F4 target configuration (Cortex-M4F)
# Usage: cmake -DUHAL_TARGET=stm32f4 -DSTM32F4_CHIP=STM32F407VG
#
# Supported chips (STM32F4_CHIP):
#   STM32F401CC  STM32F401CD  STM32F401CE
#   STM32F405OE  STM32F405OG  STM32F405RG  STM32F405VG  STM32F405ZG
#   STM32F407IE  STM32F407VE  STM32F407VG  STM32F407ZE  STM32F407ZG
#   STM32F410C8  STM32F410CB  STM32F410R8  STM32F410RB  STM32F410T8  STM32F410TB
#   STM32F411CC  STM32F411CE  STM32F411RC  STM32F411RE
#   STM32F412CE  STM32F412CG  STM32F412RE  STM32F412RG  STM32F412VE  STM32F412VG
#   STM32F412ZE  STM32F412ZG
#   STM32F413CG  STM32F413CH  STM32F413MG  STM32F413MH  STM32F413RG  STM32F413RH
#   STM32F413VG  STM32F413ZH  STM32F413ZG  STM32F413ZH
#   STM32F423CH  STM32F423MH  STM32F423RH  STM32F423VH  STM32F423ZH
#   STM32F427AG  STM32F427IG  STM32F427VG  STM32F427ZG
#   STM32F429BI  STM32F429IG  STM32F429NI  STM32F429VI  STM32F429ZI
#   STM32F437AI  STM32F437IG  STM32F437VI  STM32F437ZI
#   STM32F439AI  STM32F439BG  STM32F439IG  STM32F439NI  STM32F439VI  STM32F439ZI
#   STM32F446MC  STM32F446RC  STM32F446RE  STM32F446VC  STM32F446VE  STM32F446ZC  STM32F446ZE
#   STM32F469AI  STM32F469IE  STM32F469II  STM32F469NI  STM32F469VE  STM32F469VI
#   STM32F479AI  STM32F479BG  STM32F479IG  STM32F479II  STM32F479NI  STM32F479VI  STM32F479ZI

if(NOT DEFINED STM32F4_CHIP)
	set(STM32F4_CHIP STM32F407VG)
endif()

string(TOUPPER ${STM32F4_CHIP} STM32F4_CHIP)

# ── Chip → device header/startup mapping ─────────────────────────────

if(STM32F4_CHIP MATCHES "^STM32F401C[CD]$")
	set(F4_DEVICE "stm32f401xc")
elseif(STM32F4_CHIP MATCHES "^STM32F401CE$")
	set(F4_DEVICE "stm32f401xe")
elseif(STM32F4_CHIP MATCHES "^STM32F405[ORVZ]G$|^STM32F405OE$")
	set(F4_DEVICE "stm32f405xx")
elseif(STM32F4_CHIP MATCHES "^STM32F407[IVZ][EG]$")
	set(F4_DEVICE "stm32f407xx")
elseif(STM32F4_CHIP MATCHES "^STM32F407IE$")
	set(F4_DEVICE "stm32f407xx")
elseif(STM32F4_CHIP MATCHES "^STM32F410C[89B]$")
	set(F4_DEVICE "stm32f410cx")
elseif(STM32F4_CHIP MATCHES "^STM32F410R[89B]$")
	set(F4_DEVICE "stm32f410rx")
elseif(STM32F4_CHIP MATCHES "^STM32F410T[89B]$")
	set(F4_DEVICE "stm32f410tx")
elseif(STM32F4_CHIP MATCHES "^STM32F411[CR][CE]$")
	set(F4_DEVICE "stm32f411xe")
elseif(STM32F4_CHIP MATCHES "^STM32F412[CRVZ][EG]$")
	set(F4_DEVICE "stm32f412${F4_PIN_LEN}")
elseif(STM32F4_CHIP MATCHES "^STM32F412C[EG]$")
	set(F4_DEVICE "stm32f412cx")
elseif(STM32F4_CHIP MATCHES "^STM32F412R[EG]$")
	set(F4_DEVICE "stm32f412rx")
elseif(STM32F4_CHIP MATCHES "^STM32F412V[EG]$")
	set(F4_DEVICE "stm32f412vx")
elseif(STM32F4_CHIP MATCHES "^STM32F412Z[EG]$")
	set(F4_DEVICE "stm32f412zx")
elseif(STM32F4_CHIP MATCHES "^STM32F413[CMRVZ][GH]$")
	set(F4_DEVICE "stm32f413xx")
elseif(STM32F4_CHIP MATCHES "^STM32F423[CMRVZ]H$")
	set(F4_DEVICE "stm32f423xx")
elseif(STM32F4_CHIP MATCHES "^STM32F427[AIJVZ]G$")
	set(F4_DEVICE "stm32f427xx")
elseif(STM32F4_CHIP MATCHES "^STM32F429[IBNVZ]I$")
	set(F4_DEVICE "stm32f429xx")
elseif(STM32F4_CHIP MATCHES "^STM32F437[AIJVZ]I$")
	set(F4_DEVICE "stm32f437xx")
elseif(STM32F4_CHIP MATCHES "^STM32F439[ABINVZ]I$")
	set(F4_DEVICE "stm32f439xx")
elseif(STM32F4_CHIP MATCHES "^STM32F446[MVR][CE]$|^STM32F446Z[CE]$")
	set(F4_DEVICE "stm32f446xx")
elseif(STM32F4_CHIP MATCHES "^STM32F469[AINV]I$|^STM32F469[AE]E$")
	set(F4_DEVICE "stm32f469xx")
elseif(STM32F4_CHIP MATCHES "^STM32F479[ABINVZ]I$")
	set(F4_DEVICE "stm32f479xx")
else()
	message(FATAL_ERROR "Unsupported STM32F4 chip: ${STM32F4_CHIP}")
endif()

	string(TOUPPER ${F4_DEVICE} F4_DEFINE)
	string(REGEX REPLACE "XX$" "xx" F4_DEFINE ${F4_DEFINE})
	if(F4_DEFINE STREQUAL "STM32F401XC")
		set(F4_DEFINE STM32F401xC)
	elseif(F4_DEFINE STREQUAL "STM32F401XE")
		set(F4_DEFINE STM32F401xE)
	elseif(F4_DEFINE STREQUAL "STM32F410CX")
		set(F4_DEFINE STM32F410Cx)
	elseif(F4_DEFINE STREQUAL "STM32F410RX")
		set(F4_DEFINE STM32F410Rx)
	elseif(F4_DEFINE STREQUAL "STM32F410TX")
		set(F4_DEFINE STM32F410Tx)
	elseif(F4_DEFINE STREQUAL "STM32F411XE")
		set(F4_DEFINE STM32F411xE)
	elseif(F4_DEFINE STREQUAL "STM32F412CX")
		set(F4_DEFINE STM32F412Cx)
	elseif(F4_DEFINE STREQUAL "STM32F412RX")
		set(F4_DEFINE STM32F412Rx)
	elseif(F4_DEFINE STREQUAL "STM32F412VX")
		set(F4_DEFINE STM32F412Vx)
	elseif(F4_DEFINE STREQUAL "STM32F412ZX")
		set(F4_DEFINE STM32F412Zx)
	endif()

# ── Chip → memory map ────────────────────────────────────────────────

# Flash size (KB) based on chip suffix
if(STM32F4_CHIP MATCHES "8$")
	set(F4_FLASH_KB 64)
elseif(STM32F4_CHIP MATCHES "9$")
	set(F4_FLASH_KB 128)
elseif(STM32F4_CHIP MATCHES "B$")
	set(F4_FLASH_KB 128)
elseif(STM32F4_CHIP MATCHES "C$")
	set(F4_FLASH_KB 256)
elseif(STM32F4_CHIP MATCHES "D$")
	set(F4_FLASH_KB 384)
elseif(STM32F4_CHIP MATCHES "E$")
	set(F4_FLASH_KB 512)
elseif(STM32F4_CHIP MATCHES "G$")
	set(F4_FLASH_KB 1024)
elseif(STM32F4_CHIP MATCHES "H$")
	set(F4_FLASH_KB 1536)
elseif(STM32F4_CHIP MATCHES "I$")
	set(F4_FLASH_KB 2048)
else()
	set(F4_FLASH_KB 1024)
endif()

# RAM size (KB) based on chip family
if(STM32F4_CHIP MATCHES "^STM32F401")
	set(F4_RAM_KB 64)
elseif(STM32F4_CHIP MATCHES "^STM32F410")
	set(F4_RAM_KB 32)
elseif(STM32F4_CHIP MATCHES "^STM32F411")
	set(F4_RAM_KB 128)
elseif(STM32F4_CHIP MATCHES "^STM32F412")
	set(F4_RAM_KB 256)
elseif(STM32F4_CHIP MATCHES "^STM32F413")
	set(F4_RAM_KB 320)
elseif(STM32F4_CHIP MATCHES "^STM32F423")
	set(F4_RAM_KB 320)
elseif(STM32F4_CHIP MATCHES "^STM32F405|^STM32F407")
	set(F4_RAM_KB 192)
elseif(STM32F4_CHIP MATCHES "^STM32F427|^STM32F429|^STM32F437|^STM32F439")
	set(F4_RAM_KB 256)
elseif(STM32F4_CHIP MATCHES "^STM32F446")
	set(F4_RAM_KB 128)
elseif(STM32F4_CHIP MATCHES "^STM32F469|^STM32F479")
	set(F4_RAM_KB 384)
else()
	set(F4_RAM_KB 128)
endif()

# CCM RAM (some F4 variants have 64KB Core-Coupled Memory)
if(STM32F4_CHIP MATCHES "^STM32F40[57]|^STM32F42[79]|^STM32F43[79]|^STM32F46[79]|^STM32F479")
	set(F4_CCM_KB 64)
else()
	set(F4_CCM_KB 0)
endif()

# ── Clock (max HCLK) ─────────────────────────────────────────────────

if(STM32F4_CHIP MATCHES "^STM32F401")
	set(F4_HCLK_MHZ 84)
elseif(STM32F4_CHIP MATCHES "^STM32F410|^STM32F411")
	set(F4_HCLK_MHZ 100)
elseif(STM32F4_CHIP MATCHES "^STM32F412|^STM32F413|^STM32F423")
	set(F4_HCLK_MHZ 100)
elseif(STM32F4_CHIP MATCHES "^STM32F446")
	set(F4_HCLK_MHZ 180)
elseif(STM32F4_CHIP MATCHES "^STM32F469|^STM32F479")
	set(F4_HCLK_MHZ 180)
else()
	set(F4_HCLK_MHZ 168)
endif()

# ── UART clock ───────────────────────────────────────────────────────

# USART2 on APB1 (HCLK/2 for most, HCLK/4 for F401)
if(STM32F4_CHIP MATCHES "^STM32F401")
	set(F4_UART_CLOCK_HZ 42000000)
elseif(F4_HCLK_MHZ EQUAL 180)
	set(F4_UART_CLOCK_HZ 90000000)
elseif(F4_HCLK_MHZ EQUAL 100)
	set(F4_UART_CLOCK_HZ 50000000)
else()
	set(F4_UART_CLOCK_HZ 84000000)
endif()

# ── Toolchain settings ───────────────────────────────────────────────

set(UHAL_MCU_FLAGS "-mcpu=cortex-m4" "-mthumb" "-mfloat-abi=hard" "-mfpu=fpv4-sp-d16")
set(UHAL_TARGET_DEFINES ${F4_DEFINE})

set(UHAL_STARTUP_FILE ${CMAKE_SOURCE_DIR}/port/stm32f4/startup/startup_${F4_DEVICE}.s)

set(UHAL_LINKER_SCRIPT ${CMAKE_BINARY_DIR}/STM32F4_LINKER.ld)
configure_file(
	${CMAKE_SOURCE_DIR}/port/stm32f4/linker_scripts/STM32F4_FLASH.ld.in
	${UHAL_LINKER_SCRIPT}
	@ONLY
)

set(UHAL_PORT_SOURCES
	${CMAKE_SOURCE_DIR}/port/stm32f4/system_stm32f4xx.c
)

set(UHAL_PORT_INCLUDES
	${CMAKE_SOURCE_DIR}/cmsis/f4/Include
	${CMAKE_SOURCE_DIR}/port/stm32f4/device
	${CMAKE_SOURCE_DIR}/port/stm32f4/include
)

set(UHAL_PORT_BACKEND_DIR ${CMAKE_SOURCE_DIR}/port/stm32f4/src)

# Export UART clock for blog_uart_port.h
message(STATUS "STM32F4 chip: ${STM32F4_CHIP}")
message(STATUS "  Device:   ${F4_DEVICE}")
message(STATUS "  Define:   ${F4_DEFINE}")
message(STATUS "  Flash:    ${F4_FLASH_KB} KB")
message(STATUS "  RAM:      ${F4_RAM_KB} KB")
message(STATUS "  CCM:      ${F4_CCM_KB} KB")
message(STATUS "  HCLK:     ${F4_HCLK_MHZ} MHz")
message(STATUS "  UART clk: ${F4_UART_CLOCK_HZ} Hz")
